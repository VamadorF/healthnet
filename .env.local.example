# Este es un archivo de ejemplo para configuración local de desarrollo
# Copia este archivo a .env.local y configura tus valores

# Supabase - Obtén estas credenciales desde https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-clave-anon-publica-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-clave-service-role-secreta-aqui

# Sentry - Obtén estas credenciales desde https://sentry.io/settings/
NEXT_PUBLIC_SENTRY_DSN=https://tu-sentry-dsn@sentry.io/tu-proyecto-id
SENTRY_ORG=tu-organizacion-sentry
SENTRY_PROJECT=tu-proyecto-sentry
SENTRY_AUTH_TOKEN=tu-auth-token-sentry

# Resend - Obtén tu API key desde https://resend.com/api-keys
RESEND_API_KEY=re_tu_api_key_aqui
RESEND_FROM_EMAIL=noreply@tudominio.com

# Aplicación
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
